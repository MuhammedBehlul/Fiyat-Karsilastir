generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String
  slug      String    @unique
  products  Product[]

  @@map("categories")
}

/// Kanonik ürün kimliği: marka + model ("Apple iPhone 15"). Fiyatlar burada
/// değil, varyantlarda tutulur — 128 GB ile 256 GB ayrı SKU'dur.
model Product {
  id         Int              @id @default(autoincrement())
  brand      String?
  model      String
  modelKey   String           @unique @map("model_key")
  imageUrl   String?          @map("image_url")
  categoryId Int?             @map("category_id")
  category   Category?        @relation(fields: [categoryId], references: [id])
  variants   ProductVariant[]
  createdAt  DateTime         @default(now()) @map("created_at")

  @@map("products")
}

/// Varyant imzası: kategoriye göre tanımlı nitelik kümesi (lib/attributes.ts).
/// Bilinen değerler attrs JSONB'sinde tutulur ({"storage_gb":128,"color":"mavi"});
/// bilinmeyen alan anahtarsızdır ve variantKey'de "?" ile temsil edilir.
/// storageGb/ramGb/color eski kolonlardır: attrs'a geçiş (expand/contract)
/// tamamlanana dek çift yazılır, okuyucular taşındıktan sonra düşürülecek.
model ProductVariant {
  id           Int          @id @default(autoincrement())
  productId    Int          @map("product_id")
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  storageGb    Int?         @map("storage_gb")
  ramGb        Int?         @map("ram_gb")
  color        String?
  attrs        Json         @default("{}")
  variantKey   String       @map("variant_key")
  displayName  String       @map("display_name")
  searchKey    String       @map("search_key")
  imageUrl     String?      @map("image_url")
  priceEntries PriceEntry[]
  favorites    Favorite[]
  priceAlerts  PriceAlert[]
  createdAt    DateTime     @default(now()) @map("created_at")

  @@unique([productId, variantKey])
  @@map("product_variants")
}

model PriceEntry {
  id         Int            @id @default(autoincrement())
  variantId  Int            @map("variant_id")
  variant    ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  siteName   String         @map("site_name")
  price      Decimal        @db.Decimal(12, 2)
  currency   String         @default("TRY")
  productUrl String         @map("product_url")
  scrapedAt  DateTime       @default(now()) @map("scraped_at")

  @@index([variantId, scrapedAt])
  @@index([siteName, scrapedAt])
  @@map("price_entries")
}

/// Otomatik kabul eşiğinin altında kalan eşleşme adayları: sessizce kabul
/// edilmez, burada bekler (/admin üzerinden incelenebilir).
model MatchReview {
  id                 Int      @id @default(autoincrement())
  siteName           String   @map("site_name")
  rawTitle           String   @map("raw_title")
  productUrl         String   @map("product_url")
  price              Decimal  @db.Decimal(12, 2)
  candidateVariantId Int?     @map("candidate_variant_id")
  score              Float
  reason             String // fuzzy-model | ambiguous-variant
  status             String   @default("pending") // pending | approved | rejected
  createdAt          DateTime @default(now()) @map("created_at")

  @@index([status, createdAt])
  @@map("match_reviews")
}

/// Kayıtlı kullanıcı: e-posta + şifre (PBKDF2 hash, bkz. lib/password.ts).
/// Favoriler ve fiyat alarmları buna bağlanır.
model User {
  id           Int          @id @default(autoincrement())
  email        String       @unique
  passwordHash String       @map("password_hash")
  createdAt    DateTime     @default(now()) @map("created_at")
  favorites    Favorite[]
  priceAlerts  PriceAlert[]
  authTokens   AuthToken[]

  @@map("users")
}

/// Kullanıcının favori (takip ettiği) varyantı. Görünüm birimi varyanttır.
model Favorite {
  id        Int            @id @default(autoincrement())
  userId    Int            @map("user_id")
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  variantId Int            @map("variant_id")
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now()) @map("created_at")

  @@unique([userId, variantId])
  @@index([userId])
  @@map("favorites")
}

/// Fiyat alarmı: bir varyantın güncel en ucuz fiyatı targetPrice'ın altına
/// düşünce e-posta gider. lastNotifiedAt: aynı düşüşte tekrar tekrar bildirim
/// gönderilmemesi için (fiyat hedefin üstüne çıkınca sıfırlanır, tekrar silahlanır).
model PriceAlert {
  id             Int            @id @default(autoincrement())
  userId         Int            @map("user_id")
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  variantId      Int            @map("variant_id")
  variant        ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  targetPrice    Decimal        @map("target_price") @db.Decimal(12, 2)
  lastNotifiedAt DateTime?      @map("last_notified_at")
  createdAt      DateTime       @default(now()) @map("created_at")

  @@unique([userId, variantId])
  @@index([variantId])
  @@map("price_alerts")
}

/// Tek kullanımlık jeton (şifre sıfırlama). Ham jeton yalnızca e-postadaki
/// linktedir; DB'de SHA-256 özeti saklanır. usedAt dolunca geçersiz.
model AuthToken {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @map("token_hash")
  type      String // password_reset
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([tokenHash])
  @@map("auth_tokens")
}

model ScrapeRun {
  id               Int       @id @default(autoincrement())
  siteName         String    @map("site_name")
  startedAt        DateTime  @default(now()) @map("started_at")
  finishedAt       DateTime? @map("finished_at")
  status           String    @default("running") // running | success | error
  productsFound    Int       @default(0) @map("products_found")
  productsUpserted Int       @default(0) @map("products_upserted")
  errorMessage     String?   @map("error_message")

  @@index([siteName, startedAt])
  @@map("scrape_runs")
}
