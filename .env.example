# Supabase PostgreSQL bağlantısı
# Supabase Dashboard -> Project Settings -> Database -> Connection string

# Uygulama (Vercel) için: Transaction pooler (port 6543) + pgbouncer parametresi
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Prisma migrate için: Direct connection (port 5432)
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# sitemap.xml / robots.txt / canonical + OG URL üretimi için — prod'da gerçek
# domaininizi yazın (https://ornek.com, sondaki / olmadan). Yerelde localhost kalabilir.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Kullanıcı oturum çerezini imzalamak için gizli anahtar (HMAC-SHA256).
# Üretin: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
AUTH_SECRET="change-me-to-a-random-32-byte-string"

# E-posta gönderimi (şifre sıfırlama + fiyat alarmı bildirimleri).
# Tanımsızsa geliştirmede e-postalar konsola yazılır — üretimde bir Resend anahtarı ekleyin.
# RESEND_API_KEY="re_..."
# EMAIL_FROM="FiyatKarşılaştır <bildirim@alanadiniz.com>"

# /admin panelini korumak için paylaşımlı şifre (oturum çerezi bununla imzalanır)
ADMIN_PASSWORD="change-me"

# /admin panelindeki "Scraping başlat" butonunun .github/workflows/scrape.yml
# workflow_dispatch tetikleyicisini çağırabilmesi için gerekir.
# GitHub -> Settings -> Developer settings -> Fine-grained personal access tokens
# -> yalnızca bu repo, "Actions: Read and write" izniyle oluşturun.
GITHUB_ACTIONS_TOKEN="github_pat_..."
