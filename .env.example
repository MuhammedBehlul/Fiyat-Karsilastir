# Supabase PostgreSQL bağlantısı
# Supabase Dashboard -> Project Settings -> Database -> Connection string

# Uygulama (Vercel) için: Transaction pooler (port 6543) + pgbouncer parametresi
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Prisma migrate için: Direct connection (port 5432)
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# sitemap.xml / robots.txt / canonical + OG URL üretimi için — prod'da gerçek
# domaininizi yazın (https://ornek.com, sondaki / olmadan). Yerelde localhost kalabilir.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Yasal sayfalarda (gizlilik/KVKK) gösterilecek iletişim e-postası (opsiyonel).
# NEXT_PUBLIC_CONTACT_EMAIL="iletisim@alanadiniz.com"

# Yakalanmamış sunucu hatalarının POST edileceği webhook (opsiyonel; Discord/Slack
# webhook URL'i olabilir). Tanımsızsa hata bildirimi kapalıdır. bkz. instrumentation.ts
# ERROR_WEBHOOK_URL="https://discord.com/api/webhooks/..."

# Kullanıcı oturum çerezini imzalamak için gizli anahtar (HMAC-SHA256).
# Üretin: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
AUTH_SECRET="change-me-to-a-random-32-byte-string"

# E-posta gönderimi (şifre sıfırlama + fiyat alarmı bildirimleri).
# Tanımsızsa geliştirmede e-postalar konsola yazılır — üretimde bir Resend anahtarı ekleyin.
# RESEND_API_KEY="re_..."
# EMAIL_FROM="FiyatKarşılaştır <bildirim@alanadiniz.com>"

# Ortaklık (affiliate) linkleri — mağaza çıkış linklerine eklenecek query
# parametreleri. Tanımsızsa link aynen kalır (ortaklık yoksa sorun olmaz).
# Değer üyesi olduğunuz programdan gelir (ör. Amazon Associates tag'i).
# AFFILIATE_AMAZON_PARAMS="tag=fiyatk-21"
# AFFILIATE_TRENDYOL_PARAMS="utm_source=fiyatkarsilastir"
# AFFILIATE_HEPSIBURADA_PARAMS=""
# AFFILIATE_VATAN_PARAMS=""
# AFFILIATE_N11_PARAMS=""

# /admin panelini korumak için paylaşımlı şifre (oturum çerezi bununla imzalanır)
ADMIN_PASSWORD="change-me"

# /admin panelindeki "Scraping başlat" butonunun .github/workflows/scrape.yml
# workflow_dispatch tetikleyicisini çağırabilmesi için gerekir.
# GitHub -> Settings -> Developer settings -> Fine-grained personal access tokens
# -> yalnızca bu repo, "Actions: Read and write" izniyle oluşturun.
GITHUB_ACTIONS_TOKEN="github_pat_..."
